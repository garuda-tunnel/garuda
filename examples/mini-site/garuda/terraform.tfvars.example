# Terraform/OpenTofu variable values for examples/mini-site/garuda.
# Copy this file to terraform.tfvars and fill in your real values.
# Run infra first; then populate connection_data_* and cloudflare_* from
# infra outputs (tofu -chdir=../infra output -json > infra-outputs.tfvars.json).
#
# Sensitive values (routeros_password, firezone_admin_password, OIDC secrets)
# must not be stored in VCS. Use environment variables or a secrets manager.

env_slug = "mini-site"

# Populated from infra outputs — see README.md for the bridge command.
connection_data_hub = {
  host                 = "192.0.2.1"
  user                 = "operator"
  connection           = "ssh"
  network_os           = "linux"
  password             = null
  ssh_private_key_file = null
  ssh_private_key      = null
  instance_token       = "hub-token-placeholder"
}

connection_data_edges = {
  pt = {
    host                 = "192.0.2.2"
    user                 = "operator"
    connection           = "ssh"
    network_os           = "linux"
    password             = null
    ssh_private_key_file = null
    ssh_private_key      = null
    instance_token       = "pt-token-placeholder"
  }
  de = {
    host                 = "192.0.2.3"
    user                 = "operator"
    connection           = "ssh"
    network_os           = "linux"
    password             = null
    ssh_private_key_file = null
    ssh_private_key      = null
    instance_token       = "de-token-placeholder"
  }
}

cloudflare_hub = {
  zone_id     = "my-cloudflare-zone-id"
  record_name = "hub.example.net"
}

cloudflare_edges = {
  pt = { zone_id = "my-cloudflare-zone-id", record_name = "pt.example.net" }
  de = { zone_id = "my-cloudflare-zone-id", record_name = "de.example.net" }
}

routeros = {
  hostname         = "routeros-example"
  management_host  = "203.0.113.1"
  user             = "admin"
  uplink_interface = "ether1"
}

routeros_password    = "my-routeros-password"
routeros_lan_gateway = "203.0.113.1"

backbone_subnet        = "192.0.2.0/26"
border_subnet          = "192.0.2.64/26"
firezone_client_subnet = "198.51.100.128/25"

hub_fqdn_prefix = "hub"
base_domain     = "example.net"

edges = {
  pt = {
    machine_type        = "e2-small"
    boot_disk_gb        = 20
    region              = "us-central1"
    zone                = "us-central1-a"
    fqdn_prefix         = "pt"
    hub_cidr            = "192.0.2.129/28"
    peer_cidr           = "192.0.2.130/28"
    listen_port         = 51820
    ospf_router_id_hub  = "198.51.100.20"
    ospf_router_id_peer = "198.51.100.23"
  }
  de = {
    machine_type        = "e2-small"
    boot_disk_gb        = 20
    region              = "europe-west3"
    zone                = "europe-west3-a"
    fqdn_prefix         = "de"
    hub_cidr            = "192.0.2.145/28"
    peer_cidr           = "192.0.2.146/28"
    listen_port         = 51821
    ospf_router_id_hub  = "198.51.100.30"
    ospf_router_id_peer = "198.51.100.33"
  }
}

hub_ros = {
  hub_cidr           = "192.0.2.161/28"
  routeros_cidr      = "192.0.2.162/28"
  listen_port        = 51822
  ospf_router_id_hub = "198.51.100.21"
}

ospf_router_ids = {
  firezone   = "198.51.100.22"
  ipt_server = "198.51.100.99"
}

ipt_routes_germany_nets = []

firezone_admin_password            = "my-firezone-admin-password"
firezone_oidc_google_client_id     = "my-oidc-client-id.apps.googleusercontent.com"
firezone_oidc_google_client_secret = "my-oidc-client-secret"

smoke_client_firezone = {
  inventory_name  = "fz-client-example"
  management_host = "203.0.113.200"
  user            = "operator"
}
