{
  "$schema": "https://json-schema.org/draft-07/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["gatewayName", "gatewayClassName", "clusterIssuerName", "hostnames"],
  "properties": {
    "gatewayName":       { "type": "string", "minLength": 1 },
    "gatewayClassName":  { "type": "string", "minLength": 1 },
    "clusterIssuerName": { "type": "string", "minLength": 1 },
    "enableTraefikGatewayProvider": { "type": "boolean" },
    "labels":            { "type": "object", "additionalProperties": { "type": "string" } },
    "hostnames": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "hostname", "cert_secret_name"],
        "properties": {
          "name":             { "type": "string", "minLength": 1, "pattern": "^[a-z0-9]([-a-z0-9]*[a-z0-9])?$" },
          "hostname":         { "type": "string", "minLength": 1 },
          "cert_secret_name": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
